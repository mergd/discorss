NODE_ENV=development
# Use 'production' for Neon Postgres
DATABASE_URL=""
# Discord Bot Credentials
DISCORD_CLIENT_ID=
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_SECRET=
DEVELOPER_IDS=

# Admin web UI (Discord OAuth)
ADMIN_SESSION_SECRET=
ADMIN_OAUTH_REDIRECT_URI=http://localhost:3001/auth/callback

# OpenAI API Key (optional fallback if not using OpenRouter)
OPENAI_API_KEY=
# OpenRouter API Key (used for free-tier AI summarization)
OPENROUTER_API_KEY=

# Webhook for feedback messages
FEEDBACK_WEBHOOK_URL=

# Optional Cloudflare Worker fallback for blocked RSS fetches
# FETCH_PROXY_URL=https://discorss-rss-fetch.<your-subdomain>.workers.dev
# FETCH_PROXY_SECRET=
